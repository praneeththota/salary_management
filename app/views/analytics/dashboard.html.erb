<h1 class="text-2xl font-bold mb-6">Salary Insights</h1>

<div class="grid grid-cols-1 md:grid-cols-3 gap-4 mb-8">
  <div class="p-4 bg-blue-50 border border-blue-200 rounded-lg">
    <span class="text-sm text-blue-600 font-semibold">AVG Salary (<%= @country %>)</span>
    <div class="text-3xl font-bold">$<%= number_with_delimiter(@stats.avg.to_i) %></div>
  </div>

  <div class="p-4 bg-green-50 border border-green-200 rounded-lg">
    <span class="text-sm text-green-600 font-semibold">Title Avg (<%= @job_title %>)</span>
    <div class="text-3xl font-bold">$<%= number_with_delimiter(@job_avg.to_i) %></div>
  </div>

  <div class="p-4 bg-gray-50 border border-gray-200 rounded-lg">
    <span class="text-sm text-gray-600 font-semibold">Range (Min - Max)</span>
    <div class="text-lg font-medium">
      $<%= number_with_delimiter(@stats.min.to_i) %> - $<%= number_with_delimiter(@stats.max.to_i) %>
    </div>
  </div>
</div>